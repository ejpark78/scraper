{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ]
    },
    "viewer-mcp": {
      "url": "https://mcp.localhost/sse"
    },
    "gitea": {
      "command": "./.agents/bin/gitea-mcp",
      "args": [
        "-t", "stdio",
        "-H", "https://gitea.localhost",
        "-k"
      ]
    }
  }
}