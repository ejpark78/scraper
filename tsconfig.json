{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "*database/mongo": ["packages/database/mongo.ts"],
      "*database/meili": ["packages/database/meili.ts"],
      "*config/AppConfig": ["packages/config/AppConfig.ts"],
      "@wiki/database": ["packages/database/index.ts"],
      "@wiki/config": ["packages/config/index.ts"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "packages/**/*", "apps/**/*"],
  "exclude": ["node_modules", "dist", "src/viewer/frontend", "apps/viewer/frontend", "apps/ebook"]
}
