# ==============================================================================
# 🐳 Docker Host Path Configuration (Template)
# ==============================================================================
# Multi-compose include 구조에서 상대 경로 불일치 문제를 방지하기 위해 
# 프로젝트 최상위 루트 디렉토리의 호스트 시스템 상의 절대 경로를 기입합니다.
#
# 설정 방법: 이 파일을 .env 로 복사(cp .env.example .env)한 후, 
# 본인의 로컬 개발 머신 상의 절대 경로로 수정해 주십시오. (예: /home/user/workspace/linkedin)
HOST_PROJECT_PATH=.
TZ=Asia/Seoul

# 📧 GMail SMTP & IMAP 설정
EMAIL_USER=user@email.com
EMAIL_PASSWORD=16digit_password
IMAP_HOST=imap.gmail.com

# 🏃 LinkedIn Crawler & Worker Runtime
MONGO_URL=mongodb://mongodb:27017
REDIS_URL=redis://redis:6379
AUTH=
LIST_SLACK=0
CHUNK_SIZE=10
SESSION_DIR=/app/data/sessions
LISTS=
URLS=
HTML=
MD=
SCALE=2
JSON_LOG=true

# 🧠 AI & LLM API Keys
GEMINI_API_KEY=
OPENAI_API_KEY=anything
LLM_API_KEY=anything
OLLAMA_API_BASE=http://host.docker.internal:11434
OPENAI_API_BASE=http://host.docker.internal:11434/v1
UV_CACHE_DIR=/tmp/uv_cache
OPENKB_HOME=/data/openkb
OPENCODE_API_KEY=
SYNTHETIC_API_KEY=
Z_AI_API_KEY=

# 🗄️ Meilisearch Search Engine
MEILI_URL=http://meilisearch:7700
MEILI_ENV=development
MEILI_NO_ANALYTICS=true
MEILI_MASTER_KEY=your_meili_master_key

# 🗄️ MongoDB & Mongo Express
MONGO_INITDB_DATABASE=linkedin
MONGODB_SERVER=mongodb
ME_CONFIG_MONGODB_SERVER=mongodb
ME_CONFIG_MONGODB_PORT=27017
ME_CONFIG_MONGODB_ENABLE_ADMIN=true

# 🩺 Docker Healthcheck & Autoheal Configuration
AUTOHEAL_CONTAINER_LABEL=autoheal

# 🛸 Viewer Service
VIEWER_API_PORT=3000
VIEWER_MCP_PORT=3001
IS_VIEWER=true

# 🌐 Traefik Docker Provider
DOCKER_API_VERSION=1.40

# 🛠️ System Build & Permissions
BUILD_DATE=
VCS_REF=
USER_UID=1000
USER_GID=1000
DOCKER_GID=989

# 🐙 Gitea & Vikunja PMS Sync Configuration
# 로컬 개발 환경용 PMS(Gitea, Vikunja) API URL 및 토큰 설정
GITEA_API_URL=https://gitea.localhost/api/v1
GITEA_API_TOKEN=your_gitea_api_token
GITEA_ACCESS_TOKEN=your_gitea_access_token

# 🐙 Gitea Container Runtime
GITEA_DATABASE_DB_TYPE=sqlite3
GITEA_DATABASE_PATH=/data/gitea/gitea.db
GITEA_SERVER_ROOT_URL=https://gitea.localhost/
GITEA_SERVER_SSH_PORT=2222
GITEA_SERVER_DOMAIN=gitea.localhost
GITEA_SECURITY_INSTALL_LOCK=true
GITEA_SECURITY_ADMIN_USERNAME=gitea-admin
GITEA_SECURITY_ADMIN_PASSWORD=admin12345
GITEA_SECURITY_ADMIN_EMAIL=admin@example.com
GITEA_ACTIONS_ENABLED=true
GITEA_REPOSITORY_UNIT_DISABLED_REPOSITORY_UNITS=
GITEA_REPOSITORY_UNIT_DEFAULT_REPOSITORY_UNITS=code,issues,pulls,releases,wiki
GITEA_INSTANCE_URL=http://gitea:3000
GITEA_RUNNER_REGISTRATION_TOKEN_FILE=/data/token
GITEA_RUNNER_NAME=local-runner
GITEA_RUNNER_LABELS=ubuntu-latest:docker://node:18-bullseye,ubuntu-22.04:docker://node:18-bullseye

# 📝 Joplin CLI & Web Clipper API Configuration
JOPLIN_SERVER_URL=https://joplin.yourserver.com
JOPLIN_USERNAME=your_joplin_account_email
JOPLIN_PASSWORD=your_joplin_account_password
JOPLIN_DEC_PASSWORD=your_joplin_e2ee_decryption_password
JOPLIN_API_URL=http://host.docker.internal:41184
JOPLIN_TOKEN=your_joplin_web_clipper_token
