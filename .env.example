# ==============================================================================
# 🐳 Docker Host Path Configuration (Template)
# ==============================================================================
# Multi-compose include 구조에서 상대 경로 불일치 문제를 방지하기 위해 
# 프로젝트 최상위 루트 디렉토리의 호스트 시스템 상의 절대 경로를 기입합니다.
#
# 설정 방법: 이 파일을 .env 로 복사(cp .env.example .env)한 후, 
# 본인의 로컬 개발 머신 상의 절대 경로로 수정해 주십시오. (예: /home/user/workspace/linkedin)
HOST_PROJECT_PATH=.

# GMail SMTP 설정
EMAIL_USER=user@email.com
EMAIL_PASSWORD=16digit_password

# 📊 onWatch API Quota Monitor
ANTIGRAVITY_BASE_URL=http://127.0.0.1:46177
ANTIGRAVITY_CSRF_TOKEN=

# USER_UID/USER_GID
USER_UID=1000
USER_GID=1000
DOCKER_GID=989

# 🐙 Gitea & Vikunja PMS Sync Configuration
# 로컬 개발 환경용 PMS(Gitea, Vikunja) API URL 및 토큰 설정
GITEA_API_URL=https://gitea.127.0.0.1.nip.io/api/v1
GITEA_API_TOKEN=your_gitea_api_token
VIKUNJA_API_URL=https://vikunja.127.0.0.1.nip.io/api/v1
VIKUNJA_API_TOKEN=your_vikunja_api_token
# 🧠 LLM Knowledge Base Configuration
GEMINI_API_KEY=your_gemini_api_key_here
