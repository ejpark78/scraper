{
  "name": "scraper-root",
  "version": "1.0.0",
  "description": "Development Root Workspace for LinkedIn Clipper Project",
  "private": true,
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint:crawler": "npm run lint --prefix apps/crawler",
    "lint:viewer": "npm run lint --prefix apps/viewer",
    "lint:ebook": "cd apps/ebook && .venv/bin/python -m poethepoet lint",
    "lint": "npm run lint:crawler && npm run lint:viewer && npm run lint:ebook",
    "format:crawler": "npm run format --prefix apps/crawler",
    "format:viewer": "npm run format --prefix apps/viewer",
    "format:ebook": "cd apps/ebook && .venv/bin/python -m poethepoet format",
    "format": "npm run format:crawler && npm run format:viewer && npm run format:ebook",
    "type-check:crawler": "npm run type-check --prefix apps/crawler",
    "type-check:viewer": "npm run type-check --prefix apps/viewer",
    "type-check:ebook": "cd apps/ebook && .venv/bin/python -m poethepoet type-check",
    "type-check": "npm run type-check:crawler && npm run type-check:viewer && npm run type-check:ebook",
    "review": "ts-node .agents/scripts/review-changes.ts",
    "gitea": "ts-node .agents/scripts/gitea.ts",
    "commit": "ts-node .agents/scripts/commit-changes.ts",
    "push": "ts-node .agents/scripts/push-changes.ts",
    "openkb": "docker compose -p scraper run --rm --entrypoint python openkb /app/src/openkb.py",
    "openkb:local": "uv run --project apps/openkb apps/openkb/src/openkb.py",
    "wiki": "docker compose -p scraper run --rm --entrypoint python openkb /app/src/update_wiki.py",
    "wiki:local": "uv run --project apps/openkb apps/openkb/src/update_wiki.py",
    "agents:sessions": "ts-node --project apps/agents/tsconfig.json apps/agents/sessions.ts",
    "agents:rules": "ts-node --project apps/agents/tsconfig.json apps/agents/rules.ts",
    "agents:usage": "ts-node --project apps/agents/tsconfig.json apps/agents/usage.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
