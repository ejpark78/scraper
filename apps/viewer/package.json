{
  "name": "@wiki/viewer",
  "version": "1.0.0",
  "description": "Express & Model Context Protocol (MCP) Server for LinkedIn Clipper Dashboard",
  "main": "src/api/server.ts",
  "scripts": {
    "start": "ts-node src/api/server.ts",
    "mcp": "ts-node src/mcp/mcp-entry.ts",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "ioredis": "^5.11.0",
    "mongodb": "^6.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^25.9.2",
    "eslint": "^9.21.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
