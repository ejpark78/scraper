{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "lib": ["es2022", "dom"],
    "types": ["node"],
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "*database/mongo": ["../../packages/database/mongo.ts"],
      "*database/meili": ["../../packages/database/meili.ts"],
      "*config/AppConfig": ["../../packages/config/AppConfig.ts"],
      "@wiki/database": ["../../packages/database/index.ts"],
      "@wiki/config": ["../../packages/config/index.ts"]
    }
  },
  "include": ["src/**/*", "tests/**/*"]
}
