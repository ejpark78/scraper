  "dependencies": {
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "fs-extra": "^11.3.5",
    "imapflow": "^1.3.6",
    "ioredis": "^5.11.0",
    "jsdom": "^29.1.1",
    "mailparser": "^3.9.9",
    "mongodb": "^6.5.0",
    "opencode-gemini-auth": "^1.4.15",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/jsdom": "^28.0.3",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^25.9.2",
    "@types/turndown": "^5.0.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
