{
  "name": "@wiki/crawler",
  "version": "1.0.0",
  "description": "TypeScript-based Scraper, Converter, and Indexer for LinkedIn Clipper",
  "main": "src/cli-list.ts",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "scrape:gpters:list": "ts-node src/cli-list.ts --site gpters",
    "scrape:gpters:refresh-urls": "ts-node src/cli-refresh-urls.ts --site gpters",
    "scrape:gpters:refresh-silver": "ts-node src/cli-refresh-silver.ts --site gpters",
    "scrape:geeknews:list": "ts-node src/cli-list.ts --site geeknews",
    "scrape:geeknews:refresh-urls": "ts-node src/cli-refresh-urls.ts --site geeknews",
    "scrape:geeknews:refresh-silver": "ts-node src/cli-refresh-silver.ts --site geeknews",
    "scrape:dailydoseofds:list": "ts-node src/cli-list.ts --site dailydoseofds",
    "scrape:dailydoseofds:refresh-urls": "ts-node src/cli-refresh-urls.ts --site dailydoseofds",
    "scrape:dailydoseofds:refresh-silver": "ts-node src/cli-refresh-silver.ts --site dailydoseofds",
    "scrape:pytorch_kr:list": "ts-node src/cli-list.ts --site pytorch_kr",
    "scrape:pytorch_kr:refresh-urls": "ts-node src/cli-refresh-urls.ts --site pytorch_kr",
    "scrape:pytorch_kr:refresh-silver": "ts-node src/cli-refresh-silver.ts --site pytorch_kr",
    "scrape:aicasebook:list": "ts-node src/cli-list.ts --site aicasebook",
    "scrape:aicasebook:refresh-urls": "ts-node src/cli-refresh-urls.ts --site aicasebook",
    "scrape:aicasebook:refresh-silver": "ts-node src/cli-refresh-silver.ts --site aicasebook",
    "scrape:uppity:list": "ts-node src/cli-list.ts --site uppity",
    "scrape:uppity:refresh-urls": "ts-node src/cli-refresh-urls.ts --site uppity",
    "scrape:uppity:refresh-silver": "ts-node src/cli-refresh-silver.ts --site uppity",
    "scrape:maily_josh:list": "ts-node src/cli-list.ts --site maily_josh",
    "scrape:maily_josh:refresh-urls": "ts-node src/cli-refresh-urls.ts --site maily_josh",
    "scrape:maily_josh:refresh-silver": "ts-node src/cli-refresh-silver.ts --site maily_josh",
    "scrape:yozm:list": "ts-node src/cli-list.ts --site yozm",
