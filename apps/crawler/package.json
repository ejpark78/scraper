    "scrape:linkedin:refresh-urls": "ts-node src/cli-refresh-urls.ts --site linkedin",
    "scrape:linkedin:refresh-silver": "ts-node src/cli-refresh-silver.ts --site linkedin",
    "gmail:sync": "ts-node src/tools/gmail/gmail.ts",
    "queue:clear": "ts-node src/scripts/queue.ts --clear",
    "queue:status": "ts-node src/scripts/queue.ts --status",
    "queue:dump": "ts-node src/scripts/queue.ts --dump",
    "queue:fix-urls": "ts-node src/scripts/fix-urls.ts",
    "log:grep-errors": "ts-node src/scripts/grep-errors.ts",
    "config:generate": "ts-node src/scripts/generate-sites-config.ts",
    "test:urls": "ts-node -P tsconfig.json tests/sites/linkedin/UrlManager.test.ts",
    "test:mcp": "ts-node -P tsconfig.json tests/sites/linkedin/McpClient.test.ts",
    "test:recursive": "ts-node -P tsconfig.json tests/recursive/RecursiveScrape.test.ts",
